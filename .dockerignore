# Local dev environment
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Secrets - never bake into images
.env
.env.*
!.env.example

# dbt local profiles file (use profiles.example.yml in the image instead)
dbt/profiles.yml

# dbt build artifacts (we run `dbt deps` in the Dockerfile)
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Git / editor / OS
.git/
.gitignore
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs - keep image lean
README.md

# run.ps1 is a Windows launcher; the container invokes run.py directly
run.ps1
