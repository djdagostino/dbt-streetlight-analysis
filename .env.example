# Copy this file to ".env" in the same directory, then fill in real values.
# .env is gitignored and must never be committed.
#
# Both ingest/sync_wge.py and dbt's profiles.yml read these variables.
# Activate.ps1 loads them into your shell session.

# ============================================================================
# WGE source server (read-only access to UIS data)
# ============================================================================
# Server can be:  hostname  |  hostname\instance  |  ip,port
WGE_SERVER=10.32.1.143,1433
WGE_DATABASE=WGE
# Leave WGE_USER / WGE_PASSWORD empty to use Windows integrated auth.
# Set them to use SQL authentication (e.g. a service account).
WGE_USER=YOUR_WGE_SQL_LOGIN
WGE_PASSWORD=YOUR_WGE_PASSWORD

# ============================================================================
# Warehouse server (where dbt builds raw / staging / marts schemas)
# ============================================================================
WAREHOUSE_SERVER=YOUR_WAREHOUSE_SERVER\YOUR_WAREHOUSE_INSTANCE
WAREHOUSE_DATABASE=your_warehouse_database
# Leave WAREHOUSE_USER / WAREHOUSE_PASSWORD empty for Windows integrated auth.
WAREHOUSE_USER=
WAREHOUSE_PASSWORD=

# ============================================================================
# ODBC driver shared by ingest script and dbt
# ============================================================================
# Find what's installed:  Get-OdbcDriver | Where-Object Name -like '*SQL Server*'
SQLSERVER_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Trust self-signed certs ("yes" for typical internal SQL; "no" if real CA cert installed)
SQLSERVER_TRUST_CERT=yes
